# API Keys Configuration Guide
# Copy this file to .env and fill in your actual API keys

# Threat Source Mode: "mock" (default), "real" (requires keys), or "hybrid" (real with fallback)
# THREAT_SOURCE_MODE=mock

# # AbuseIPDB API Key
# # Get FREE API key from: https://www.abuseipdb.com/register
# # No payment required, generous free tier available
# ABUSEIPDB_API_KEY=

# # AlienVault OTX API Key  
# # Get FREE API key from: https://otx.alienvault.com/
# # Free account provides access to threat intelligence data
# ALIENVAULT_API_KEY=

THREAT_SOURCE_MODE=hybrid
ABUSEIPDB_API_KEY=YOUR_ABUSEIPDB_API_KEY_HERE
ALIENVAULT_API_KEY=YOUR_ALIENVAULT_API_KEY_HERE
# Instructions:
# 1. Register for free accounts at both services (links above)
# 2. Get your API keys from their dashboards
# 3. Copy your API keys to the variables above (remove the # comments)
# 4. Run: docker compose --env-file .env up --build
# 5. The services will fetch real threat intelligence data


